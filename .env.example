# ─────────────────────────────────────────────────────────────────────────────
# INSECAP Capacitaciones – Variables de entorno
# Copia este archivo como `.env.local` (desarrollo) o `.env.production` (prod)
# y rellena los valores según el entorno.
# NUNCA subas a git los archivos .env, .env.local ni .env.production.
# ─────────────────────────────────────────────────────────────────────────────

# ── TMS API ──────────────────────────────────────────────────────────────────
# URL base del TMS para las llamadas del frontend.
# • En PRODUCCIÓN: poner la URL real  →  https://tms.insecap.cl
# • En LOCAL: dejar vacío para que Vite use el proxy inverso definido en vite.config.ts
VITE_TMS_API_URL=

# ── Proxy Vite (solo desarrollo local) ───────────────────────────────────────
# URL destino del proxy de Vite. Solo se lee desde vite.config.ts, no desde el
# frontend. Puede ser un túnel ngrok, la URL real del TMS, etc.
# No se necesita en producción (Vercel/servidor no usa el proxy de Vite).
TMS_PROXY_TARGET=

# ── E-Commerce ───────────────────────────────────────────────────────────────
# Activa o desactiva el flujo completo de compras (carrito, checkout, Shopify).
# Valores válidos: true | false
VITE_ECOMMERCE_ENABLED=false
VITE_URL_APPSTORE=https://apps.apple.com/cl/app/relatoresya/id6742147110
VITE_URL_PLAYSTORE=https://play.google.com/store/apps/details?id=com.insecap.relatoresya&pcampaignid=web_share
